# ============================================================================
# Backend Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ============================================================================

# ── Application Settings ────────────────────────────────────────────────────
APP_NAME="Analyst Copilot"
APP_VERSION="1.0.0"
ENVIRONMENT="development"  # development | staging | production
DEBUG=true
LOG_LEVEL="INFO"  # DEBUG | INFO | WARNING | ERROR

# ── API Server ──────────────────────────────────────────────────────────────
API_HOST="0.0.0.0"
API_PORT=8000
API_RELOAD=true  # Auto-reload on code changes (dev only)

# ── CORS (Cross-Origin Resource Sharing) ────────────────────────────────────
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"  # Comma-separated

# ── Database ────────────────────────────────────────────────────────────────
# Development (SQLite)
DATABASE_URL="sqlite+aiosqlite:///./analyst_copilot.db"

# Production (PostgreSQL) — uncomment and configure:
# DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/analyst_copilot"

# ── LLM Provider (Choose one) ───────────────────────────────────────────────
# OpenAI (GPT-4)
OPENAI_API_KEY="sk-your-openai-key-here"
OPENAI_MODEL="gpt-4-turbo-preview"  # gpt-4-turbo-preview | gpt-3.5-turbo

# Google Gemini (Alternative)
# GOOGLE_API_KEY="your-google-ai-key-here"
# GEMINI_MODEL="gemini-1.5-pro"

# Azure OpenAI (For Air Force GovCloud)
# AZURE_OPENAI_API_KEY="your-azure-key"
# AZURE_OPENAI_ENDPOINT="https://your-resource.openai.azure.com/"
# AZURE_OPENAI_DEPLOYMENT="gpt-4"
# AZURE_OPENAI_API_VERSION="2024-02-15-preview"

# ── Vector Database (ChromaDB) ──────────────────────────────────────────────
CHROMA_PERSIST_DIR="./chroma_db"  # Local storage path
CHROMA_COLLECTION_MITRE="mitre_techniques"
CHROMA_COLLECTION_MISP="misp_events"

# ── MITRE ATT&CK ────────────────────────────────────────────────────────────
MITRE_TAXII_URL="https://attack-taxii.mitre.org/taxii2/"
MITRE_DATA_DIR="../../data/mitre"  # Relative to backend/src

# ── MISP (Threat Intel) ─────────────────────────────────────────────────────
MISP_ENABLED=false  # Set to true when MISP instance is available
MISP_URL="https://misp.example.local"
MISP_API_KEY="your-misp-api-key"
MISP_VERIFY_SSL=true

# ── Feature Flags ───────────────────────────────────────────────────────────
ENABLE_RAG=true  # Enable RAG-powered report generation
ENABLE_PROVENANCE_TRACKING=true  # Track LLM calls and references
ENABLE_METRICS=false  # Prometheus metrics endpoint
ENABLE_AUTH=false  # OAuth2 authentication (future)

# ── Caching (Optional) ──────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379/0"  # Uncomment if using Redis
CACHE_TTL_SECONDS=3600  # 1 hour

# ── Security ────────────────────────────────────────────────────────────────
SECRET_KEY="your-secret-key-for-jwt-tokens"  # Generate: openssl rand -hex 32
ACCESS_TOKEN_EXPIRE_MINUTES=30
